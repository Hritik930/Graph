public class Graph{
    int adjMatrix[][]; //Declare Graph
    Graph(int nodes){
        adjMatrix = new int[nodes][nodes]; //initialize graph
    }
    
    public void addEdgesWithWeightedInMatrix(int edges[][], boolean isDirected){
        for(int edge[] : edges){
            int U = edge[0]; //starting node of the edge
            int V = edge[1]; //ending node of the edge
            int W = edge[2];
            
            if(isDirected){  //Directed
                adjMatrix[U][V] = W; 
            }else{  //Undirected
                adjMatrix[U][V] = W; 
                adjMatrix[V][U] = W;
            }
        }
        System.out.println();
    }
    
    public void printMatrix(){
        for(int i = 0; i<adjMatrix.length; i++){
            System.out.print("row " + i + "->");
            for(int j = 0; j<adjMatrix[i].length; j++){
                System.out.print(adjMatrix[i][j] + ",");
            }
            System.out.println();
        }
    }
    
    public static void main(String [] args){
        int edges[][]= {{0,1,10},{0,2,20},{1,3, 30}};
        int nodes = 4;
        
        // Weighted Undirected Graph
        Graph graph = new Graph(nodes);
        graph.addEdgesWithWeightedInMatrix(edges,false);
        graph.printMatrix();
        
        // Weighted Directed Graph
        Graph graph1 = new Graph(nodes);
        graph1.addEdgesWithWeightedInMatrix(edges,true);
        graph1.printMatrix();
    }
}
