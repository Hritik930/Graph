import java.util.HashMap;

class Solution {
    public int findCenter(int[][] edges) {
        HashMap<Integer, Integer> freqMap = new HashMap<Integer, Integer>();
        int totalEdges = edges.length; // 3 in your example

        for (int i = 0; i < edges.length; i++) {
            int v1 = edges[i][0];
            int v2 = edges[i][1];
            
            // Fixed the typo "get0rDefault" to "getOrDefault" and removed the '@'
            freqMap.put(v1, freqMap.getOrDefault(v1, 0) + 1);
            freqMap.put(v2, freqMap.getOrDefault(v2, 0) + 1);
            
            // Added missing closing brackets for the if statements
            if (freqMap.get(v1) == totalEdges) {
                return v1;
            }
            
            if (freqMap.get(v2) == totalEdges) {
                return v2;
            }
        } // Added missing closing bracket for the for loop
        
        return -1;
    }
}
